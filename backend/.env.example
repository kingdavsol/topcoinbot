# Email
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=postmaster@coinpicker.us
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# Security
ADMIN_REGISTRATION_SECRET=change_me
ENCRYPTION_KEY=change_me

# Database (SQLite by default - path to db file)
DATABASE_URL=sqlite:////var/www/topcoinbot-backend-new/trading_bot.db

# Server
PORT=8000
FRONTEND_URL=https://topcoinbot.coinpicker.us

# Optional
JWT_SECRET_KEY=change_me_to_random_secret
GOOGLE_OAUTH_CLIENT_ID=
TELEGRAM_BOT_TOKEN=
